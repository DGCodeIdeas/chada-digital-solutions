---
import Icon from './Icon.astro';
import siteData from '../data/site.json';

const { services } = siteData;
---

<section class="px-6 py-20 md:py-28" id="services">
  <div class="mx-auto max-w-7xl">
    <div class="mb-14 text-center">
      <span class="text-xs font-semibold uppercase tracking-[0.3em] text-primary">{services.badge}</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight md:text-5xl">{services.title} <span class="text-primary">{services.titleHighlight}</span></h2>
      <p class="mt-4 max-w-2xl mx-auto text-base text-muted-foreground">{services.description}</p>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.services.map((service) => (
        <div class="group rounded-2xl border border-border bg-card/40 p-8 transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-card/60">
          <div class="mb-5 inline-flex size-12 items-center justify-center rounded-xl bg-primary/15 text-primary">
            <Icon name={service.icon} size={24} class="size-6" strokeWidth={1.75} />
          </div>
          <h3 class="font-display text-lg font-bold tracking-tight">{service.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{service.description}</p>
          <a class="mt-6 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-widest text-primary transition-colors group-hover:text-primary-foreground" href={service.link.href}>
            {service.link.text}
            <Icon name="arrow-right" size={12} class="size-3 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
