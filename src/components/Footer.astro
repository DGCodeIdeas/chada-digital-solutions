---
import Icon from './Icon.astro';
import siteData from '../data/site.json';

const { footer } = siteData;
const year = new Date().getFullYear();
---

<footer class="border-t border-border/40 bg-card/40 px-6 py-16">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <img alt="Chada Digital" class="h-10 w-auto object-contain" src="/chada-logo-horizontal.png" />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-muted-foreground">{footer.tagline}</p>
      </div>
      {footer.columns.map((column) => (
        <div>
          <h4 class="font-display text-sm font-semibold uppercase tracking-widest">{column.title}</h4>
          <ul class="mt-6 space-y-3">
            {column.links.map((link) => (
              <li>
                <a class="text-sm text-muted-foreground transition-colors hover:text-foreground" href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener' : undefined}>{link.text}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-12 border-t border-border/40 pt-8 text-center">
      <p class="text-sm text-muted-foreground">{footer.copyright.replace('{year}', String(year))}</p>
    </div>
  </div>
</footer>
