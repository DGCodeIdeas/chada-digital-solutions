---
import Icon from './Icon.astro';
import siteData from '../data/site.json';

const { contact } = siteData;
---

<section class="border-t border-border/40 px-6 py-20 md:py-28" id="contact">
  <div class="mx-auto grid max-w-7xl gap-16 lg:grid-cols-2">
    <div>
      <span class="text-xs font-semibold uppercase tracking-[0.3em] text-primary">{contact.badge}</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight md:text-5xl">{contact.title} <span class="text-primary">{contact.titleHighlight}</span></h2>
      <p class="mt-6 max-w-lg text-base leading-relaxed text-muted-foreground">{contact.description}</p>
      <div class="mt-10 space-y-6">
        {contact.info.map((item) => (
          <div class="flex items-start gap-4">
            <div class="inline-flex size-10 shrink-0 items-center justify-center rounded-xl bg-primary/15 text-primary">
              <Icon name={item.icon} size={18} class="size-[18px]" strokeWidth={1.75} />
            </div>
            <div>
              <p class="text-sm font-semibold text-muted-foreground">{item.label}</p>
              <p class="font-semibold text-foreground">{item.value}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-10 flex gap-4">
        {contact.socials.map((social) => (
          <a href={social.href} target="_blank" rel="noopener" aria-label={social.label} class="inline-flex size-10 items-center justify-center rounded-xl border border-border text-muted-foreground transition-colors hover:border-primary hover:text-primary">
            <Icon name={social.icon} size={18} class="size-[18px]" strokeWidth={1.75} />
          </a>
        ))}
      </div>
    </div>
    <div class="rounded-2xl border border-border bg-card/40 p-8 md:p-10">
      <form id="chada-contact-form" class="space-y-6">
        {contact.form.fields.map((field) => (
          <div>
            <label class="mb-2 block text-sm font-medium" for={field.name}>{field.label}</label>
            {field.type === 'textarea' ? (
              <textarea id={field.name} name={field.name} rows={field.rows} required={field.required} placeholder={field.placeholder} class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"></textarea>
            ) : (
              <input id={field.name} name={field.name} type={field.type} required={field.required} placeholder={field.placeholder} class="w-full rounded-xl border border-border bg-background px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" />
            )}
          </div>
        ))}
        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-primary px-7 py-3.5 text-xs font-semibold uppercase tracking-widest text-primary-foreground transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-primary/30">
          {contact.form.submitText}
          <Icon name="arrow-right" size={16} class="size-4" />
        </button>
      </form>
    </div>
  </div>
</section>
