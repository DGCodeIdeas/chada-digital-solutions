---
import SEO from '@/components/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <SEO {...props} />
</head>
<body>
  <slot />
  <script src="/assets/js/main.js" defer></script>
</body>
</html>