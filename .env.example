# ============================================
# Chada Digital - Environment Configuration
# ============================================
# This file serves as a template for required environment variables.
# Copy this file to .env and fill in your values for local development.
# 
# For Vercel deployment:
# 1. Go to your Vercel project dashboard
# 2. Navigate to Settings > Environment Variables
# 3. Add each variable below with your production values
# 4. Set the environment to "Production" (and "Preview" if needed)
# ============================================

# ============================================
# Admin Dashboard Configuration
# ============================================

# Admin email to receive contact form submissions
# This is where form submissions will be sent
ADMIN_EMAIL=hello@chadadigital.com

# Admin password hash (bcrypt)
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
# Or use an online bcrypt generator tool
# REQUIRED: Without this, admin login will not work
ADMIN_PASSWORD_HASH=$2a$14$bGOiPdGpexMHMkdsbdVbteOVlPfE2qizuWKvuIC8Ttnay2oOfWacG

# Session secret for signing session cookies
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Change this in production for security
SESSION_SECRET=a51c91cb9e5ee716f5f297a2db57c2cba81aa660eb96431a37cf96a31607cd14

# ============================================
# Email/SMTP Configuration
# ============================================
# Configure your SMTP settings for the contact form to send emails.
# You can use Gmail, SendGrid, Mailgun, or any SMTP provider.

# SMTP server host
EMAIL_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
EMAIL_PORT=587

# SMTP authentication email/user
EMAIL_USER=your-email@gmail.com

# SMTP authentication password or app-specific password
# For Gmail: Use an App Password (not your regular password)
# For SendGrid: Use "apikey" as user and your API key as password
EMAIL_PASS=your-app-password

# ============================================
# Zohomail Configuration (Recommended)
# ============================================
# Zohomail SMTP settings for sending emails
# Get your credentials from: https://www.zoho.com/mail/

# Zohomail SMTP server host
ZOHO_MAIL_HOST=smtp.zoho.com

# Zohomail SMTP server port (587 for TLS, 465 for SSL)
ZOHO_MAIL_PORT=587

# Zohomail email address (your full email)
ZOHO_MAIL_USER=your-email@yourdomain.com

# Zohomail password or app-specific password
# For Zohomail: Generate an App Password in Security > App Passwords
ZOHO_MAIL_PASS=your-zoho-app-password

# From email address (defaults to ZOHO_MAIL_USER if not set)
ZOHO_MAIL_FROM_EMAIL=your-email@yourdomain.com

# ============================================
# Alternative Email Providers (uncomment to use)
# ============================================

# SendGrid Configuration
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=SG.your-sendgrid-api-key

# Mailgun Configuration
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USER=postmaster@your-domain.com
# EMAIL_PASS=your-mailgun-password

# ============================================
# Vercel Environment Notes
# ============================================
# - All variables above should be added to Vercel dashboard
# - Do NOT commit .env file with real values to version control
# - Environment variables in Vercel are automatically injected at build time
# - For preview deployments, you can set different values in Vercel
# - The .gitignore file already excludes .env from commits