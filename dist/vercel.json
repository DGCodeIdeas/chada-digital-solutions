{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/demos/sterling-vale/about",
      "destination": "/demos/sterling-vale/about/index.html"
    },
    {
      "source": "/demos/sterling-vale/projects",
      "destination": "/demos/sterling-vale/projects/index.html"
    },
    {
      "source": "/demos/sterling-vale/services",
      "destination": "/demos/sterling-vale/services/index.html"
    },
    {
      "source": "/demos/sterling-vale/contact",
      "destination": "/demos/sterling-vale/contact/index.html"
    }
  ]
}
